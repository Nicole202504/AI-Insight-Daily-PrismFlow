# Server Configuration
PORT=3000
JWT_SECRET=your_jwt_secret_key_here

# Database Configuration
DATABASE_PATH=./data/database.sqlite

# Daily RSS Gemini-compatible summarization
APIMART_BASE_URL=https://api.apimart.ai/v1beta
APIMART_MODEL=gemini-3.5-flash
APIMART_API_KEY=your_apimart_token_here
DAILY_SUMMARY_LIMIT=999
DAILY_ASSETS_DIR=daily-assets
DAILY_IMAGE_PREFIX=/daily-assets

# WeChat Performance & Resource Limits
WECHAT_MAX_CONCURRENT=2
WECHAT_SHARP_THREADS=1
WECHAT_FFMPEG_THREADS=1
